<!--pages/complete-info/complete-info.wxml - 首次登录完善信息页面-->
<view class="container">
  <view class="header">
    <view class="title">完善个人信息</view>
    <view class="subtitle">请填写您的基本信息，以便我们为您提供更好的服务</view>
  </view>

  <view class="form-card">
    <view class="form-item">
      <view class="label">姓名<text class="required">*</text></view>
      <input 
        class="input" 
        placeholder="请输入您的姓名" 
        value="{{name}}"
        bindinput="onInput"
        data-field="name"
      />
    </view>

    <view class="form-item">
      <view class="label">性别<text class="required">*</text></view>
      <view class="radio-group">
        <label class="radio-item">
          <radio value="男" checked="{{gender === '男'}}" color="#4A90D9"/> 男
        </label>
        <label class="radio-item">
          <radio value="女" checked="{{gender === '女'}}" color="#4A90D9"/> 女
        </label>
      </view>
    </view>

    <view class="form-item">
      <view class="label">年龄<text class="required">*</text></view>
      <picker mode="selector" range="{{ages}}" value="{{ageIndex}}" bindchange="onAgeChange">
        <view class="picker">
          {{ageIndex > 0 ? ages[ageIndex] : '请选择年龄'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="label">手机号<text class="required">*</text></view>
      <input 
        class="input" 
        type="number"
        maxlength="11"
        placeholder="请输入您的手机号" 
        value="{{phone}}"
        bindinput="onInput"
        data-field="phone"
      />
    </view>

    <view class="form-item">
      <view class="label">既往病史</view>
      <textarea 
        class="textarea" 
        placeholder="如有高血压、糖尿病等慢性病，请在此填写（没有可填无）" 
        value="{{medicalHistory}}"
        bindinput="onInput"
        data-field="medicalHistory"
        maxlength="200"
      />
    </view>

    <view class="form-item">
      <view class="label">过敏史</view>
      <textarea 
        class="textarea" 
        placeholder="如对青霉素、磺胺类等药物过敏，请在此填写（没有可填无）" 
        value="{{allergyHistory}}"
        bindinput="onInput"
        data-field="allergyHistory"
        maxlength="200"
      />
    </view>
  </view>

  <view class="tips">
    <view class="tips-title">温馨提示</view>
    <view class="tips-content">
      <text>1. 带</text><text class="required">*</text><text>为必填项</text>
    </view>
    <view class="tips-content">
      <text>2. 我们将严格保护您的个人信息安全</text>
    </view>
    <view class="tips-content">
      <text>3. 填写完成后才能使用复诊、咨询等功能</text>
    </view>
  </view>

  <view class="button-group">
    <button class="submit-btn" bindtap="onSubmit" disabled="{{!canSubmit}}">提交信息</button>
  </view>
</view>
